# RSA Keys for JWT signing
# These keys are used by auth-service to sign and verify tokens

# NOTE: These keys are only intended for local development with docker compose,
# and can safely be committed. Actual production keys are loaded into the
# environment by k8s deployment.

# Private key in base64 (PKCS8 unencrypted, no headers)
JWT_RSA_PRIVATE_

# Public key in base64 (X509, no headers)
JWT_RSA_PUBLIC_
