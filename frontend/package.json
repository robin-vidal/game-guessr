    "next-themes": "^0.4.6",
    "openapi-fetch": "^0.17.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.0",
